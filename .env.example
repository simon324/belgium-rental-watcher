# --- Built-in scrapers: criteria (override defaults in lib/config.ts) ---
WATCH_POSTAL_CODES=8000,8200,8310
WATCH_MAX_PRICE=1000
WATCH_MIN_BEDROOMS=0
WATCH_PROPERTY_TYPE=both

# --- Custom URLs ---
# Comma-separated. Each gets fetched and Claude extracts listings from the HTML.
# Skip if you don't have an ANTHROPIC_API_KEY.
WATCH_URLS=

# Free-text matching preferences for the LLM scorer (e.g. "near canal, quiet, no ground floor").
WATCH_PREFERENCES=

# --- LLM (bring your own key, via OpenRouter) ---
# Required for: WATCH_URLS extraction, match scoring/summarization.
# OpenRouter is a unified gateway — one key works for Claude, GPT, Gemini, Llama, etc.
# Get one at https://openrouter.ai/keys (free signup, pay-as-you-go).
OPENROUTER_API_KEY=

# Optional: override the default model. Examples:
#   anthropic/claude-haiku-4.5     (default — fast, cheap)
#   anthropic/claude-sonnet-4.6    (better reasoning, ~5x cost)
#   openai/gpt-5-mini              (alternative)
#   google/gemini-2.5-flash        (alternative)
WATCH_LLM_MODEL=

# --- Notifications ---
NOTIFY_EMAIL=simon.mestdagh@tangent.works
RESEND_API_KEY=
RESEND_FROM=Belgium Rental Watcher <onboarding@resend.dev>

# --- Cron security ---
CRON_SECRET=
